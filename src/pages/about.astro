---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="about">
  <article class="page">
    <h1>* about / untitled-space</h1>

    <pre class="ascii-block">{`+-- untitled-space ---------------+
|                                  |
|  > System initialized.           |
|  > Memory: fragmented.           |
|  > Time: non-linear.             |
|  > Welcome.                      |
+----------------------------------+`}
    </pre>

    <p>
      This is a space for thoughts, experiments, and explorations — 
      written in the margins of a rapidly digitizing world.
    </p>

    <p>
      Built with Astro, deployed on GitHub Pages. No frameworks. No trends. Just code.
    </p>

    <h2>~ contact</h2>
    <ul>
      <li>Email: <a href="mailto:hello@example.com">hello@example.com</a></li>
      <li>GitHub: <a href="https://github.com/your-username">@your-username</a></li>
    </ul>

    <hr />

    <h2>~ colophon</h2>
    <table>
      <tr><th>property</th><th>value</th></tr>
      <tr><td>engine</td><td>Astro 5</td></tr>
      <tr><td>typeface</td><td>JetBrains Mono</td></tr>
      <tr><td>palette</td><td>blue-green (#00FFCC / #0066FF)</td></tr>
      <tr><td>deployment</td><td>GitHub Pages</td></tr>
    </table>
  </article>
</BaseLayout>

<style>
  .page {
    max-width: var(--max-width);
  }

  .page h1 {
    margin-top: 0;
  }

  .ascii-block {
    font-size: var(--font-size-sm);
    color: var(--color-cyan);
    line-height: 1.4;
    margin: var(--space-lg) 0;
  }
</style>
