---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const recentPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const recentNotes = (await getCollection("notes"))
  .filter((n) => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<BaseLayout title="index">
  <section class="hero">
    <pre class="hero__ascii">{`+------------------------------------------+
|        untitled-space v0.1                |
|   ~ enter the void ~                      |
+------------------------------------------+`}
    </pre>
    <p class="hero__subtitle">
      A personal blog at the intersection of code, design, and retro futures.
    </p>
  </section>

  <section class="section">
    <h2 class="section__title">* latest posts</h2>
    {
      recentPosts.length > 0 ? (
        <ul class="post-list">
          {recentPosts.map((post) => (
            <li class="post-list__item">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
              <span class="post-list__meta">{post.data.date.toLocaleDateString("zh-CN")}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty">~ no posts yet</p>
      )
    }
    <a href="/blog" class="section__more">> view all posts</a>
  </section>

  <section class="section">
    <h2 class="section__title">* latest notes</h2>
    {
      recentNotes.length > 0 ? (
        <ul class="post-list">
          {recentNotes.map((note) => (
            <li class="post-list__item">
              <a href={`/notes/${note.id}`}>{note.data.title}</a>
              <span class="post-list__meta">{note.data.date.toLocaleDateString("zh-CN")}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty">~ no notes yet</p>
      )
    }
    <a href="/notes" class="section__more">> view all notes</a>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .hero__ascii {
    font-size: var(--font-size-sm);
    color: var(--color-cyan);
    line-height: 1.4;
    display: inline-block;
    text-align: left;
    border: var(--border-width) dotted var(--color-border);
    padding: var(--space-md);
  }

  .hero__subtitle {
    color: var(--color-text-muted);
    margin-top: var(--space-md);
    font-size: var(--font-size-sm);
  }

  .section {
    margin-bottom: var(--space-xl);
  }

  .section__title {
    font-size: var(--font-size-lg);
    margin-top: 0;
    margin-bottom: var(--space-md);
    color: var(--color-teal);
  }

  .section__more {
    display: inline-block;
    margin-top: var(--space-sm);
    font-size: var(--font-size-sm);
  }

  .post-list {
    list-style: none;
    padding: 0;
  }

  .post-list__item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-xs) 0;
    border-bottom: 1px dotted var(--color-border-dashed);
  }

  .post-list__meta {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    flex-shrink: 0;
    margin-left: var(--space-md);
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
    font-size: var(--font-size-sm);
  }
</style>
