---
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || "untitled-space"} />
    <title>{title} :: untitled-space</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="layout">
      <header class="header">
        <a href="/" class="header__logo">untitled-space</a>
        <nav class="header__nav">
          <a href="/">~ index</a>
          <a href="/blog">/ blog</a>
          <a href="/notes">/ notes</a>
          <a href="/about">/ about</a>
        </nav>
      </header>

      <main class="main">
        <slot />
      </main>

      <footer class="footer">
        <pre class="footer__ascii">
{`<*> handmade with cat /\\_/\\
    ( o.o )
     > ^ <`}
        </pre>
      </footer>
    </div>
  </body>
</html>

<style>
  .layout {
    max-width: var(--max-width);
    margin: 0 auto;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: var(--space-md);
    border-bottom: var(--border-width) dashed var(--color-border-dashed);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .header__logo {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--color-cyan);
    text-decoration: none;
  }

  .header__logo:visited {
    color: var(--color-cyan);
  }

  .header__logo:hover {
    color: var(--color-blue);
  }

  .header__nav {
    display: flex;
    gap: var(--space-md);
  }

  .header__nav a {
    font-size: var(--font-size-sm);
    text-transform: lowercase;
  }

  .main {
    flex: 1;
  }

  .footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-md);
    border-top: var(--border-width) dashed var(--color-border-dashed);
  }

  .footer__ascii {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    text-align: center;
    line-height: 1.3;
  }
</style>
